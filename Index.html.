
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beautiful Life Facts</title>
<style>
    body {
        font-family: Arial, sans-serif;
        text-align: center;
        background: linear-gradient(135deg, #ff9a9e, #fad0c4);
        margin: 0;
        padding: 50px;
        color: #333;
    }

    .container {
        background: white;
        padding: 30px;
        border-radius: 20px;
        max-width: 500px;
        margin: auto;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    h1 {
        font-size: 2rem;
    }

    p {
        font-size: 1.2rem;
        min-height: 80px;
    }

    button {
        background: #ff758c;
        color: white;
        border: none;
        padding: 15px 25px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 1rem;
    }

    button:hover {
        opacity: 0.8;
    }
</style>
</head>
<body>

<div class="container">
    <h1>✨ Beautiful Life Facts</h1>
    <p id="fact">Click the button to see a fun fact!</p>
    <button onclick="showFact()">Show Fact</button>
</div>

<script>
const facts = [
    "🌍 The Earth travels around the Sun at 67,000 mph.",
    "🧠 Your brain uses 20% of your body's energy.",
    "💧 Water can exist as solid, liquid, and gas naturally on Earth.",
    "🌙 The Moon is slowly moving away from Earth every year.",
    "🌱 Plants can communicate with each other underground."
];

function showFact() {
    const randomIndex = Math.floor(Math.random() * facts.length);
    document.getElementById("fact").innerText = facts[randomIndex];
}
</script>

</body>
</html>
